# BitModel VPS config — copied to /etc/bitmodel.env
# Public address peers use to reach this box.
BITMODEL_PUBLIC_IP=YOUR_VPS_IP

# Registry (manifests + seeder announces)
BITMODEL_REGISTRY=http://YOUR_VPS_IP:8090
BITMODEL_REGISTRY_BIND=0.0.0.0:8090
BITMODEL_REGISTRY_DB=/opt/bitmodel/data/registry.db
# Shared bearer token required to publish manifests (set to a real secret!)
BITMODEL_REGISTRY_TOKEN=change-me-please
BITMODEL_TOKEN=change-me-please

# Self-hosted relay (plain-HTTP dev relay; no domain/TLS needed)
BITMODEL_RELAY=http://YOUR_VPS_IP:3340

# Anchor seeder iroh UDP port (must be opened in ufw)
BITMODEL_PORT=11204

# Demo model the anchor validator fetches + seeds
BITMODEL_MODEL=tinyllama-1.1b
BITMODEL_MODEL_VERSION=1
BITMODEL_ORIGIN_BASE=https://huggingface.co/TheBloke/TinyLlama-1.1B-Chat-v1.0-GGUF/resolve/main
BITMODEL_MODEL_FILES=tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
BITMODEL_VALIDATOR_ID=mirror-a
